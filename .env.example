# ---- Telegram ----
# Токен бота из @BotFather
BOT_TOKEN=123456:ABCdefGhIJKlmNoPQRstuVWxyz

# Telegram ID руководителей (через запятую). Свой ID узнать у @userinfobot
ADMIN_IDS=111111111

# ---- База данных ----
DB_PATH=taskbot.db

# ---- Google Sheets ----
# 1 = выгружать в Google Sheets, 0 = выключить
SHEETS_ENABLED=1
# URL опубликованного Apps Script Web App, который принимает sync_tasks/weekly
GOOGLE_SHEETS_WEBHOOK=https://script.google.com/macros/s/XXXXX/exec
# Секретный токен, который проверяет Apps Script
SHEETS_TOKEN=change-me
# Ссылка на таблицу-реестр для команды /table
SHEET_URL=https://docs.google.com/spreadsheets/d/1_TCrhPNXrtEwugspD-FRn86-90vsGg9hp-CwC17uXsQ/edit

# ---- Еженедельный отчёт ----
# День недели и время автосбора (mon..sun), время в 24ч
WEEKLY_REPORT_DAY=fri
WEEKLY_REPORT_TIME=18:00
# Часовой пояс
TIMEZONE=Europe/Moscow
