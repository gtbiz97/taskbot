# ---- Telegram ----
# Токен бота из @BotFather
BOT_TOKEN=123456:ABCdefGhIJKlmNoPQRstuVWxyz

# Telegram ID руководителей (через запятую). Свой ID узнать у @userinfobot
ADMIN_IDS=111111111

# ---- База данных ----
DB_PATH=taskbot.db

# ---- Google Sheets ----
# 1 = выгружать в Google Sheets, 0 = выключить
SHEETS_ENABLED=1
# Путь к JSON ключу сервисного аккаунта Google
GOOGLE_CREDENTIALS=service_account.json
# ID таблицы Google (из URL: docs.google.com/spreadsheets/d/<ЭТО_ID>/edit)
SPREADSHEET_ID=

# ---- Еженедельный отчёт ----
# День недели и время автосбора (mon..sun), время в 24ч
WEEKLY_REPORT_DAY=fri
WEEKLY_REPORT_TIME=18:00
# Часовой пояс
TIMEZONE=Europe/Moscow
